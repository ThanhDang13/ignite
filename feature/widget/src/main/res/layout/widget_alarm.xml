<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_no_alarm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No upcoming alarms"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/widget_alarm_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/widget_alarm_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Morning Alarm"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <TextView
            android:id="@+id/widget_alarm_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mon, May 20 at 7:00 AM"
            android:textSize="14sp"
            android:textColor="#CCCCCC"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</LinearLayout>
